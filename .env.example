# Seats.aero Partner API key (required, Pro account access needed)
SEATS_API_KEY=

# SMTP server host (e.g., Gmail uses smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# SMTP port: 587 for TLS (recommended), 465 for SSL
SMTP_PORT=587
# SMTP login username (for Gmail, your full Gmail address)
SMTP_USER=
# SMTP password (for Gmail, use a 16-char App Password, not your normal password)
SMTP_PASS=
# Recipient email for alerts
ALERT_TO_EMAIL=
# Sender email shown in alert messages (usually same as SMTP_USER)
ALERT_FROM_EMAIL=

# Enable STARTTLS (set true for port 587)
SMTP_TLS=true
# Enable implicit SSL (set true for port 465, usually false for 587)
SMTP_SSL=false
